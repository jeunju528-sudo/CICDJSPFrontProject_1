<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sist.model.food-mapper">
	<select id="foodFindData" resultType="FoodVO" parameterType="hashmap">
		SELECT no, name, poster, address, type
		 FROM food
		<where> 
			${column} LIKE '%'||#{ss}||'%'
			 <!-- 
			 	앞에 추가 : prefix
			 	뒤에 추가 : suffix
			 	문장이 없는 경우 앞에 AND / OR 삭제 : prefixOverrides , suffixOverrides
			  -->
		    <if test="fdArr != null">
		        AND
		        <trim prefix="(" suffix=")" prefixOverrides="OR|AND">
		            <foreach collection="fdArr" item="fd">
		                <trim prefix="OR">
		                    <choose>
		                        <when test="fd == 'A'.toString()">type LIKE '%한식%'</when>
		                        <when test="fd == 'B'.toString()">type LIKE '%양식%'</when>
		                        <when test="fd == 'C'.toString()">type LIKE '%일식%'</when>
		                        <when test="fd == 'D'.toString()">type LIKE '%중식%'</when>
		                        <when test="fd == 'E'.toString()">type LIKE '%분식%'</when>
		                    </choose>
		                </trim>
		            </foreach>
		        </trim>
		    </if>
		 </where>
		 ORDER BY no ASC
		 OFFSET #{start} ROWS FETCH NEXT 12 ROWS ONLY
	</select>
	<select id="foodFindCount" resultType="int" parameterType="hashmap">
		SELECT count(*)
		 FROM food
		<where>
		    ${column} LIKE '%'||#{ss}||'%'
		    <if test="fdArr != null">
		        AND
		        <trim prefix="(" suffix=")" prefixOverrides="OR|AND">
		            <foreach collection="fdArr" item="fd">
		                <trim prefix="OR">
		                    <choose>
		                        <when test="fd == 'A'.toString()">type LIKE '%한식%'</when>
		                        <when test="fd == 'B'.toString()">type LIKE '%양식%'</when>
		                        <when test="fd == 'C'.toString()">type LIKE '%일식%'</when>
		                        <when test="fd == 'D'.toString()">type LIKE '%중식%'</when>
		                        <when test="fd == 'E'.toString()">type LIKE '%분식%'</when>
		                    </choose>
		                </trim>
		            </foreach>
		        </trim>
		    </if>
		</where>
	</select>
</mapper>